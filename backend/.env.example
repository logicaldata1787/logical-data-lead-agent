# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=https://your-app.up.railway.app

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── Gmail OAuth (preferred for sending) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.up.railway.app/api/email-accounts/oauth/callback

# ── SMTP fallback (Gmail App Password or any SMTP) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=your@gmail.com

# ── Lead sourcing ─────────────────────────────────────────────────────────────
APOLLO_API_KEY=

# ── Demo / Safety ─────────────────────────────────────────────────────────────
DEMO_MODE=true
DISABLE_WORKER=false
WORKER_INTERVAL_MS=60000
