# Backend environment variables (copy this file to .env and fill values)

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database (recommended: use a single DATABASE_URL from Supabase/Railway)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# JWT (change to a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Email providers (choose one or more)
# 1) Brevo (Sendinblue) API (recommended free tier)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=LogicalData Solution

# 2) Gmail SMTP (requires Google App Password)
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SMTP_SECURE=false
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=

# 3) Outlook / Microsoft 365 SMTP
OUTLOOK_SMTP_HOST=smtp.office365.com
OUTLOOK_SMTP_PORT=587
OUTLOOK_SMTP_SECURE=false
OUTLOOK_EMAIL=
OUTLOOK_PASSWORD=

# 4) Custom SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=LogicalData Solution

# Optional lead data / scraping integrations
APOLLO_API_KEY=
APIFY_API_TOKEN=

# Rate limiting / safety
MAX_EMAILS_PER_DAY=300
MAX_EMAILS_PER_HOUR=50
